#!/usr/bin/env bash
#
# Dotfiles Bootstrap Script
# Usage: curl -fsSL https://raw.githubusercontent.com/Bowser1704/dotfiles/master/bootstrap | bash
#   or:  ./bootstrap [options]
#
# Options:
#   -h, --help          Show this help message
#   --no-root           Skip operations requiring root/sudo
#   --skip-packages     Skip system package installation
#   --skip-asdf         Skip asdf installation (Linux only)
#   --skip-shell        Skip shell configuration
#   --skip-user-create  Skip user creation (used internally)
#   --proxy URL         Use proxy for GitHub (default: https://gh-proxy.org/)
#   --no-proxy          Disable GitHub proxy
#   --dry-run           Show what would be done without executing
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Default options
NO_ROOT=false
SKIP_PACKAGES=false
SKIP_ASDF=false
SKIP_SHELL=false
SKIP_USER_CREATE=false
DRY_RUN=false
NEW_USER=""
ASDF_PROXY="${ASDF_GITHUB_PROXY:-https://gh-proxy.org/}"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            sed -n '1,/^$/p' "$0" | sed 's/^#//' | tail -n +2
            exit 0
            ;;
        --no-root)
            NO_ROOT=true
            shift
            ;;
        --skip-packages)
            SKIP_PACKAGES=true
            shift
            ;;
        --skip-asdf)
            SKIP_ASDF=true
            shift
            ;;
        --skip-shell)
            SKIP_SHELL=true
            shift
            ;;
        --skip-user-create)
            SKIP_USER_CREATE=true
            shift
            ;;
        --proxy)
            shift
            ASDF_PROXY="$1"
            shift
            ;;
        --no-proxy)
            ASDF_PROXY=""
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            exit 1
            ;;
    esac
done

# Logging functions
info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Detect operating system
detect_os() {
    case "$(uname -s)" in
        Darwin*) echo "macos" ;;
        Linux*)
            if [ -f /etc/os-release ]; then
                . /etc/os-release
                case "$ID" in
                    ubuntu|debian) echo "ubuntu" ;;
                    arch|manjaro) echo "arch" ;;
                    fedora|rhel|centos) echo "fedora" ;;
                    *) echo "linux" ;;
                esac
            else
                echo "linux"
            fi
            ;;
        *) echo "unknown" ;;
    esac
}

# Clone dotfiles if running remotely
clone_dotfiles() {
    if [ ! -d "$HOME/.dotfiles" ]; then
        info "Cloning dotfiles repository..."
        git clone https://github.com/Bowser1704/dotfiles.git "$HOME/.dotfiles"
    else
        info "Dotfiles repository already exists"
    fi
    cd "$HOME/.dotfiles"
}

# Run with sudo if available
run_sudo() {
    if [ "$NO_ROOT" = true ]; then
        warn "Skipping (no-root mode): $*"
        return 1
    fi
    if [ "$EUID" -eq 0 ]; then
        "$@"
    elif command -v sudo &> /dev/null; then
        sudo "$@"
    else
        warn "No sudo access, skipping: $*"
        return 1
    fi
}

# Backup existing config files
backup_configs() {
    info "Backing up existing configuration files..."

    local files=(
        "$HOME/.zshrc"
        "$HOME/.tmux.conf"
        "$HOME/.tool-versions"
        "$HOME/.ruff.toml"
        "$HOME/.stylua.toml"
        "$HOME/.config/nvim"
        "$HOME/.config/alacritty"
        "$HOME/.config/zellij"
        "$HOME/.config/ghostty"
        "$HOME/.config/flashspace"
    )

    for file in "${files[@]}"; do
        if [ -e "$file" ] && [ ! -L "$file" ]; then
            local backup="${file}.backup.$(date +%Y%m%d%H%M%S)"
            mv "$file" "$backup"
            info "Backed up $file -> $backup"
        fi
    done
}

# Create new user on Linux
create_user() {
    info "Creating new user..."

    # Prompt for username
    local username
    while true; do
        read -rp "Enter username for new user: " username
        if [ -z "$username" ]; then
            error "Username cannot be empty"
            continue
        fi
        if id "$username" &>/dev/null; then
            warn "User '$username' already exists"
            read -rp "Use existing user '$username'? [y/N]: " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                break
            else
                continue
            fi
        fi
        break
    done

    # Prompt for password
    local password
    while true; do
        read -rsp "Enter password for '$username': " password
        echo
        if [ -z "$password" ]; then
            error "Password cannot be empty"
            continue
        fi
        local password_confirm
        read -rsp "Confirm password: " password_confirm
        echo
        if [ "$password" != "$password_confirm" ]; then
            error "Passwords do not match"
            continue
        fi
        break
    done

    # Create user if not exists
    if ! id "$username" &>/dev/null; then
        info "Creating user '$username'..."
        run_sudo useradd -m -s /bin/bash "$username"
        echo "$username:$password" | run_sudo chpasswd
    fi

    # Add to sudo group
    info "Adding '$username' to sudo group..."
    if grep -q "^sudo:" /etc/group; then
        run_sudo usermod -aG sudo "$username"
    elif grep -q "^wheel:" /etc/group; then
        run_sudo usermod -aG wheel "$username"
    else
        run_sudo groupadd -f sudo
        run_sudo usermod -aG sudo "$username"
    fi

    # Set up passwordless sudo (optional)
    read -rp "Enable passwordless sudo for '$username'? [y/N]: " passwordless
    if [[ "$passwordless" =~ ^[Yy]$ ]]; then
        echo "$username ALL=(ALL) NOPASSWD:ALL" | run_sudo tee "/etc/sudoers.d/$username" > /dev/null
        run_sudo chmod 440 "/etc/sudoers.d/$username"
        info "Passwordless sudo enabled for '$username'"
    fi

    success "User '$username' created with sudo privileges"

    # Export for later use
    NEW_USER="$username"
}

# Switch to new user and continue setup
switch_user_and_run() {
    if [ -z "$NEW_USER" ]; then
        return 0
    fi

    local dotfiles_dir="$HOME/.dotfiles"

    # If we're running as root, switch to new user
    if [ "$EUID" -eq 0 ] && [ -n "$NEW_USER" ]; then
        info "Switching to user '$NEW_USER' to continue setup..."

        # Copy dotfiles to new user's home
        local user_home
        user_home=$(eval echo "~$NEW_USER")

        if [ "$dotfiles_dir" != "$user_home/.dotfiles" ]; then
            cp -r "$dotfiles_dir" "$user_home/.dotfiles"
            chown -R "$NEW_USER:$NEW_USER" "$user_home/.dotfiles"
        fi

        # Run bootstrap as new user
        local proxy_args=""
        [ -n "$ASDF_PROXY" ] && proxy_args="--proxy $ASDF_PROXY"
        exec su - "$NEW_USER" -c "cd $user_home/.dotfiles && ./bootstrap --skip-user-create $proxy_args"
    fi
}

# Install on Ubuntu/Debian
install_ubuntu() {
    info "Setting up Ubuntu/Debian system..."

    if [ "$SKIP_PACKAGES" = false ]; then
        info "Installing system packages (build dependencies for asdf tools)..."
        run_sudo apt update
        run_sudo apt install -y \
            git curl wget build-essential pkg-config \
            libssl-dev libreadline-dev zlib1g-dev libffi-dev \
            libbz2-dev libsqlite3-dev libncurses5-dev libncursesw5-dev \
            libgmp-dev autoconf bison unzip ca-certificates sudo zsh
    fi

    if [ "$SKIP_ASDF" = false ]; then
        info "Installing asdf and tools (this may take a while)..."

        # Build proxy args
        local proxy_args=""
        if [ -n "$ASDF_PROXY" ]; then
            proxy_args="--proxy $ASDF_PROXY"
            export ASDF_GITHUB_PROXY="$ASDF_PROXY"
        fi

        ./scripts/install-asdf.sh $proxy_args
    fi
}

# Install on macOS
install_macos() {
    info "Setting up macOS system..."

    # Check for Xcode CLI tools
    if ! xcode-select -p &> /dev/null; then
        info "Installing Xcode Command Line Tools..."
        xcode-select --install 2>/dev/null || true
        info "Please complete Xcode CLI installation and press Enter to continue..."
        read -r
    fi

    # Install Homebrew
    if ! command -v brew &> /dev/null; then
        info "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

        # Add to PATH for Apple Silicon
        if [ -d "/opt/homebrew" ]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        elif [ -d "/usr/local/Homebrew" ]; then
            eval "$(/usr/local/Homebrew/bin/brew shellenv)"
        fi
    fi

    if [ "$SKIP_PACKAGES" = false ]; then
        info "Installing packages from Brewfile..."
        brew bundle --file "$HOME/.dotfiles/packages/Brewfile"
    fi
}

# Configure shell
configure_shell() {
    if [ "$SKIP_SHELL" = true ]; then
        return 0
    fi

    info "Configuring shell..."

    local zsh_path
    zsh_path=$(command -v zsh)

    if [ -z "$zsh_path" ]; then
        error "zsh not found"
        return 1
    fi

    # Add zsh to /etc/shells if needed
    if ! grep -q "^${zsh_path}$" /etc/shells 2>/dev/null; then
        if [ -w /etc/shells ]; then
            echo "$zsh_path" >> /etc/shells
        else
            echo "$zsh_path" | run_sudo tee -a /etc/shells > /dev/null
        fi
    fi

    # Change default shell
    if [ "$SHELL" != "$zsh_path" ]; then
        chsh -s "$zsh_path" 2>/dev/null || run_sudo chsh -s "$zsh_path" "$USER"
    fi

    # Install TPM
    if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
        info "Installing TPM..."
        git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
    fi

    success "Shell configured"
}

# Run Dotbot
run_dotbot() {
    info "Linking configuration files..."

    # Initialize dotbot submodule if needed
    git submodule update --init --recursive dotbot

    # Run dotbot
    ./install
}

# Post-installation
post_install() {
    info "Running post-installation..."

    # Create directories
    mkdir -p "$HOME/.local/bin"
    mkdir -p "$HOME/.local/share"

    # Install Neovim plugins if available
    if command -v nvim &> /dev/null; then
        info "Installing Neovim plugins..."
        nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
    fi

    success "Post-installation complete"
}

# Main
main() {
    echo ""
    echo "========================================"
    echo "       Dotfiles Bootstrap Script       "
    echo "========================================"
    echo ""

    if [ "$DRY_RUN" = true ]; then
        warn "Dry run mode - no changes will be made"
        echo ""
    fi

    # Detect OS first
    OS=$(detect_os)
    info "Detected OS: $OS"

    if [ "$OS" = "unknown" ]; then
        error "Unsupported operating system"
        exit 1
    fi

    # Create new user on Linux if running as root and not skipped
    if [ "$OS" = "ubuntu" ] && [ "$EUID" -eq 0 ] && [ "$SKIP_USER_CREATE" = false ]; then
        if [ "$DRY_RUN" = true ]; then
            info "[DRY-RUN] Would prompt for new user creation"
        else
            create_user
            switch_user_and_run
            # switch_user_and_run will exec and not return
        fi
    fi

    # Clone dotfiles if needed
    clone_dotfiles

    # Backup existing configs
    backup_configs

    # OS-specific installation
    case "$OS" in
        ubuntu)
            if [ "$DRY_RUN" = true ]; then
                info "[DRY-RUN] Would install apt packages and asdf tools"
            else
                install_ubuntu
            fi
            ;;
        macos)
            if [ "$DRY_RUN" = true ]; then
                info "[DRY-RUN] Would install Homebrew and packages"
            else
                install_macos
            fi
            ;;
        arch|fedora|linux)
            warn "Full support for $OS is not implemented yet"
            warn "Installing asdf and linking configs only..."
            if [ "$DRY_RUN" = false ] && [ "$SKIP_ASDF" = false ]; then
                ./scripts/install-asdf.sh
            fi
            ;;
    esac

    # Run Dotbot
    if [ "$DRY_RUN" = true ]; then
        info "[DRY-RUN] Would run Dotbot to link configuration files"
    else
        run_dotbot
    fi

    # Configure shell
    if [ "$DRY_RUN" = true ]; then
        info "[DRY-RUN] Would configure zsh as default shell"
    else
        configure_shell
    fi

    # Post-installation
    if [ "$DRY_RUN" = true ]; then
        info "[DRY-RUN] Would run post-installation setup"
    else
        post_install
    fi

    echo ""
    echo "========================================"
    success "Bootstrap complete!"
    echo "========================================"
    echo ""
    echo "Next steps:"
    echo "  1. Restart your terminal or run: exec zsh"
    echo "  2. (Tmux) Press prefix + I to install plugins"
    echo "  3. (Neovim) Run :checkhealth to verify setup"
    echo ""
}

# Run main
main
